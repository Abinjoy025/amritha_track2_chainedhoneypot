# ─────────────────────────────────────────────────────────────────────────────
# Honeyport – environment variables
# Copy this file to .env and fill in your credentials.
# All services (Flask honeypot, FastAPI, controller, watchdog, frontend) read
# from this single file.
# ─────────────────────────────────────────────────────────────────────────────

# ── Flask Honeypot (app.py) ───────────────────────────────────────────────────
# Secret key for Flask session signing – change before deploying!
FLASK_SECRET=change-me-in-production

# ── Phase 3: OSINT ────────────────────────────────────────────────────────────
# AbuseIPDB  →  https://www.abuseipdb.com/account/api
ABUSEIPDB_API_KEY=your_abuseipdb_key_here
# Shodan     →  https://account.shodan.io/
SHODAN_API_KEY=your_shodan_key_here

# ── Phase 4: IPFS (Pinata) ────────────────────────────────────────────────────
# Pinata JWT →  https://app.pinata.cloud/developers/api-keys  (create a new key, copy the JWT)
PINATA_JWT=your_pinata_jwt_here

# ── Phase 4: Ethereum / Sepolia testnet ───────────────────────────────────────
# Infura     →  https://app.infura.io/  (create a project, copy Project ID)
WEB3_PROVIDER_URL=https://sepolia.infura.io/v3/YOUR_INFURA_PROJECT_ID
# Contract address after deploying AttackEvidenceStorage.sol to Sepolia
HONEYPORT_CONTRACT_ADDRESS=0xDeployedContractAddressOnSepolia
# Your Sepolia wallet private key (keep secret, NEVER commit)
ETH_PRIVATE_KEY=0xYourPrivateKeyHere

# ── Frontend (Vite / React) ───────────────────────────────────────────────────
# Same contract address as above (used by Web3Ledger.jsx)
VITE_CONTRACT_ADDRESS=0xDeployedContractAddressOnSepolia
# Public Sepolia RPC for the browser wallet (can use the Infura URL above or a public one)
VITE_RPC_URL=https://rpc.sepolia.org
# WebSocket URL for the live attack feed (FastAPI /ws/live)
VITE_WS_URL=ws://localhost:8000/ws/live

# ── Phase 1: Infrastructure ───────────────────────────────────────────────────
# IP of the Honeyport Flask container on Network B (matches docker-compose.yml)
HONEYPOT_IP=192.168.200.10
# Port the Flask honeypot listens on inside the container
HONEYPOT_PORT=5000
HONEYPOT_CONTAINER=honeyport_app

# ── Paths (defaults match docker-compose.yml volume mounts) ──────────────────
NGINX_ACCESS_LOG=/logs/nginx/access.log
ZEEK_LOG_DIR=/logs/zeek
# honeypot_logs.json is written by app.py and tailed by controller.py
HONEYPOT_LOG=/logs/honeyport/honeypot_logs.json
COWRIE_LOG_DIR=/logs/honeyport
COWRIE_DL_DIR=/data/honeyport_dl
BLOCKLIST_FILE=/data/blocklist.txt

# ── API ───────────────────────────────────────────────────────────────────────
API_BASE_URL=http://127.0.0.1:8000

# ── Watchdog ─────────────────────────────────────────────────────────────────
BRUTE_THRESHOLD=3
WINDOW_SECONDS=60

# ── SOAR ──────────────────────────────────────────────────────────────────────
SOAR_CONF_THRESHOLD=0.90
